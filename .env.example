# 必填：OpenAI 或兼容接口的原始 token，不要带 `Bearer ` 前缀。
OPENAI_API_KEY=sk-your-token

# 可选：兼容接口地址；直连官方 OpenAI 时可留空或删除。
OPENAI_BASE_URL=https://your-compatible-endpoint/v1

# 可选：默认模型名。
OPENAI_MODEL=gpt-5.2-codex

# 可选：子代理 light 路由使用的模型名。
LIGHT_OPENAI_MODEL=gpt-5

# 可选：统一工具输出截断阈值。
TOOL_OUTPUT_MAX_LINES=200
TOOL_OUTPUT_MAX_BYTES=12288

# 可选：完整工具输出落盘目录，路径相对项目根目录。
TOOL_OUTPUT_DIR=artifacts/tool-output

# 可选：是否开启本地 tracing。第三方兼容接口下不使用 Agents SDK 官方 tracing，而是写本地 JSONL。
TRACE_ENABLED=true

# 可选：本地 trace 落盘目录，路径相对项目根目录。
TRACE_DIR=artifacts/traces

# 可选：是否对 trace 中的明显 token 做最小脱敏。
TRACE_SANITIZE=true

# 可选：长会话自动压缩阈值。估算上下文 token 达到该值后触发 auto_compact。
CONTEXT_COMPACT_TRIGGER_TOKENS=12000

# 可选：至少积累多少条历史 items 后，auto_compact 才会真正触发。
CONTEXT_COMPACT_MIN_MESSAGES=8

# 可选：auto_compact 后保留在 session 中的最近 items 数量。
CONTEXT_COMPACT_KEEP_RECENT_ITEMS=12

# 可选：完整旧历史归档目录，路径相对项目根目录。
CONTEXT_COMPACT_ARCHIVE_DIR=artifacts/compaction

# 可选：micro_compact 至少看到多少条 tool_result 后才开始压缩旧工具结果。
CONTEXT_MICRO_COMPACT_MIN_TOOL_RESULTS=6

# 可选：micro_compact 保留最近多少条完整 tool_result。
CONTEXT_MICRO_COMPACT_KEEP_RECENT_TOOL_RESULTS=3

# 可选：只有超过该字符数的旧 tool_result 才会被替换成占位文本。
CONTEXT_MICRO_COMPACT_LONG_RESULT_MIN_CHARS=600

# 可选：L1 中 skills 简表的最大字符预算。
SKILLS_PROMPT_CHAR_BUDGET=12000

# 可选：是否在每次 Skill 调用前按 mtime 自动刷新 skills 索引。
SKILLS_REFRESH_ON_CALL=true
